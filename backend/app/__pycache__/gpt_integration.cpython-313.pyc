from transformers import pipeline

# ✅ Correct pipeline for Flan-T5
generator = pipeline("text2text-generation", model="google/flan-t5-base")

def huggingface_generate_answer(prompt: str) -> str:
    formatted_prompt = f"You are an expert academic tutor. Answer the question clearly:\nQuestion: {prompt}\nAnswer:"
    response = generator(formatted_prompt, max_length=100, temperature=0.5)
    return response[0]['generated_text'].strip()

